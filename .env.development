# Development Environment Configuration
VITE_ENVIRONMENT=DEVELOPMENT

# API Endpoints (proxied through Vite in dev)
VITE_ADMIN_API_URL=/admin
VITE_SCORING_API_URL=/v1

# Sentry (disabled in development by default)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLE_IN_DEV=false
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_SESSION_RATE=0
VITE_SENTRY_REPLAYS_ERROR_RATE=0
