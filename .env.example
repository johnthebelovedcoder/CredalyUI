# CredalyUI Environment Variables
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the appropriate values.

# Environment: DEVELOVELOPMENT | STAGING | PRODUCTION
VITE_ENVIRONMENT=DEVELOPMENT

# API Endpoints
VITE_ADMIN_API_URL=http://localhost:3001
VITE_SCORING_API_URL=http://localhost:8000

# Sentry (error monitoring) — leave blank to disable
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLE_IN_DEV=false
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_RATE=0.1
VITE_SENTRY_REPLAYS_ERROR_RATE=1.0
